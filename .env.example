# ─── Database ────────────────────────────────────────────────
POSTGRES_USER=argus
POSTGRES_PASSWORD=changeme
POSTGRES_DB=argus
DATABASE_URL=postgresql://argus:changeme@postgres:5432/argus

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── API ─────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret
DEBUG=false

# Comma-separated list of allowed CORS origins.
# On a VPS set this to your actual domain, e.g. https://argus.example.com
# Never use * in production — it bypasses SameSite cookie protection.
ALLOWED_ORIGINS=http://localhost:3000

# ─── Auth ────────────────────────────────────────────────────
# Sign JWT tokens. Generate a strong value with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-random-jwt-secret
JWT_EXPIRY_HOURS=24

# ─── Optional Module Keys ────────────────────────────────────
# Leave blank to disable the corresponding module

# Have I Been Pwned (https://haveibeenpwned.com/API/Key)
HIBP_API_KEY=

# Shodan (https://account.shodan.io)
SHODAN_API_KEY=

# Hunter.io (https://hunter.io/api-keys)
HUNTER_API_KEY=

# VirusTotal (https://www.virustotal.com/gui/my-apikey)
VT_API_KEY=
